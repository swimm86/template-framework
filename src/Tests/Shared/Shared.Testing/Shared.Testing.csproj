<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
    <DisableFody>true</DisableFody>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Configuration" Version="10.0.7" />
    <PackageReference Include="Microsoft.Extensions.Configuration.Json" Version="10.0.7" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="10.0.7" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" Version="10.0.7" />
    <!--
      xunit.extensibility.core нужен только для атрибутов [Fact]/[Trait] в
      JobExecutionIntegrationTestBase. xunit.v3 не подходит: он требует
      &lt;OutputType&gt;Exe&lt;/OutputType&gt; (только для тестовых проектов).
      PrivateAssets=all гарантирует, что зависимость не утечёт в потребителей
      (тестовые проекты имеют свою прямую ссылку на xunit.v3, который
      транзитивно тянет тот же xunit.v3.extensibility.core с тем же assembly identity).
    -->
    <PackageReference Include="xunit.v3.extensibility.core" Version="3.2.2">
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
    <!--
      FluentAssertions нужен для .Should().BeSameAs(...) в
      JobExecutionIntegrationTestBase. Та же изоляция PrivateAssets=all, что и
      для xunit: Shared.Testing — это библиотека тестовых утилит, поэтому
      test-framework зависимости здесь уместны, но не должны «утекать» в
      потребителей (у всех тестовых проектов своя прямая ссылка).
    -->
    <PackageReference Include="FluentAssertions" Version="7.2.2">
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\Shared\Core\Shared.Domain.Core\Shared.Domain.Core.csproj" />
    <ProjectReference Include="..\..\..\Shared\Core\Shared.Application.Core\Shared.Application.Core.csproj" />
  </ItemGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

</Project>
